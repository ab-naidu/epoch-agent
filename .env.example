# AWS Bedrock
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Aerospike
AEROSPIKE_HOST=localhost
AEROSPIKE_PORT=3000
AEROSPIKE_NAMESPACE=epoch

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://epoch-agent/api

# Bland AI
BLAND_API_KEY=your_bland_key
BLAND_PHONE_NUMBER=+1xxxxxxxxxx

# Airbyte
AIRBYTE_API_URL=http://localhost:8000
AIRBYTE_API_KEY=your_airbyte_key

# TrueFoundry
TRUEFOUNDRY_API_KEY=your_truefoundry_key
